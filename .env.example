# ===================================
# MapNexus Environment Variables
# คัดลอกไฟล์นี้เป็น .env และกรอกค่าจริง
# ===================================

# Server Configuration
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5500

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_database_username
DB_PASSWORD=your_database_password
DB_NAME=mapnexus

# JWT Secret (สร้างด้วย: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=your_jwt_secret_key_here_change_this_in_production

# Payment Gateway - PromptPay
PROMPTPAY_ID=0812345678
# หรือใช้ Tax ID: 1234567890123

# Payment Gateway - Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Payment Gateway - Bank Transfer
BANK_ACCOUNT_NUMBER=123-4-56789-0
BANK_ACCOUNT_NAME=MapNexus Co., Ltd.
BANK_NAME=ธนาคารกสิกรไทย

# Email Configuration (สำหรับส่งอีเมลยืนยัน)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# File Upload
MAX_FILE_SIZE=10485760
# 10MB in bytes

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
# 15 minutes in milliseconds
RATE_LIMIT_MAX_REQUESTS=100

# Session
SESSION_SECRET=your_session_secret_here

# API Keys (Optional)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key
WEATHER_API_KEY=your_weather_api_key

# Admin
ADMIN_EMAIL=admin@mapnexus.com
